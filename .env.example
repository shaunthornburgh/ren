# Copy to `.env` and fill in your Stripe test-mode values.
# docker-compose reads this file automatically for ${VAR} substitution.

# Stripe test-mode API keys (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:8000/api/v1/payments/webhook
# and copy the `whsec_...` value it prints.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ISO 4217 currency for Checkout line items (lowercase).
STRIPE_CURRENCY=usd
